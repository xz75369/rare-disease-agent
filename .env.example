# ===== LLM 配置（调用 DeepSeek API）=====
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxx        # DeepSeek 控制台生成
LLM_MODEL=deepseek-chat

# 如果切换到其他兼容 API（备选），例如：
# 通义千问（OpenAI 兼容模式）：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-max
# 智谱 GLM：
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4-plus
#
# 本地 vllm 部署（旧配置，保留作参考）：
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_API_KEY=EMPTY
#   LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ===== NCBI E-utilities（PubMed + ClinVar；建议填写以获更高配额）=====
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=your_email@example.com
NCBI_TOOL=rare_disease_agent

# ===== PubMed（esearch + esummary，全库）=====
ENABLE_PUBMED=true
PUBMED_TIMEOUT=20
# 每条 query 最多返回的文献数（真实 PubMed 索引）
PUBMED_MAX_RESULTS=25
# 留空 = 不按发表年过滤（全时间）；若需限制可写：2020:2026[dp]
PUBMED_DATE_FILTER=

# ===== ClinVar（db=clinvar，按基因名 esearch + esummary）=====
ENABLE_CLINVAR=true
CLINVAR_ESEARCH_RETMAX=40
CLINVAR_MAX_RECORDS_PER_GENE=5

# ===== gnomAD（GraphQL api，由 ClinVar GRCh38 + SPDI 推断 variantId）=====
ENABLE_GNOMAD=true
GNOMAD_API_URL=https://gnomad.broadinstitute.org/api
# 允许：gnomad_r4 | gnomad_r3 | gnomad_r2_1
GNOMAD_DATASET=gnomad_r4
GNOMAD_MAX_QUERIES_PER_RUN=4
GNOMAD_REQUEST_GAP_SEC=0.35

# ===== 本地知识库路径 =====
CORPUS_DIR=./data/corpus
ONTOLOGY_DIR=./data/ontology
