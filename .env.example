# 本地 vllm 部署的 LLM（OpenAI 兼容接口）
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# LLM 生成参数（小模型调优）
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# PubMed 在线检索（可选，容器能访问外网时启用；query 只含医学术语，不含患者信息）
ENABLE_PUBMED=true
PUBMED_TIMEOUT=10

# 本地知识库路径
CORPUS_DIR=./data/corpus
ONTOLOGY_DIR=./data/ontology
